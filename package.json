{
  "name": "financial-buddy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c yellow,cyan \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "cd web && vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "cd web && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "postcss": "^8.5.12",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "date-fns": "^3.3.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "openai": "^6.34.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^3.22.4"
  }
}
