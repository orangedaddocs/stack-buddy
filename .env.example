# Stack Buddy environment variables.
#
# Copy this file to .env and fill in only the providers you actually use.
# Stack Buddy's deterministic calculator works without any of these — they're
# only needed if you want the optional AI chat panel or Plan-tab advisor
# inside the app.
#
# DO NOT commit .env. The .gitignore in this repo already excludes it.
#
# Note: the recommended way to chat about your plan is to paste
# private-ai/prompt.md into a private AI host (Maple or Venice) — no env
# setup required. See private-ai/README.md for that flow. The variables
# below are only for the in-app chat panel.

# Backend port. Defaults to 2034 if unset.
# PORT=

# --- Anthropic ---
# Anthropic API key. Enables the in-app chat panel and the Plan-tab advisor.
# (The Plan-tab advisor is Anthropic-only — it uses Anthropic's tool-use
# schema specifically.) https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Maple Local Proxy / OpenAI-compatible endpoint ---
# Enable Local Proxy in the Maple desktop app, copy the API key it generates,
# paste it below. Maple's proxy fronts Kimi, GLM, DeepSeek, Llama, Gemma,
# Qwen, and GPT-OSS. Base URL defaults to http://127.0.0.1:8080/v1 if unset.
# MAPLE_BASE_URL=
MAPLE_API_KEY=

# --- OpenAI / OpenAI-compatible endpoint ---
# Direct OpenAI key, or any OpenAI-shaped API endpoint (OpenRouter, Ollama,
# LM Studio, etc.).
OPENAI_API_KEY=
